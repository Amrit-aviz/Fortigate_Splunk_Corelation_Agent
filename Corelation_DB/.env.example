# Postgres settings for syslog_events ingestion
# Set these in NCP platform runtime environment (recommended) or locally for dev.

SYSLOG_DB_HOST=10.4.4.174
SYSLOG_DB_PORT=5432
SYSLOG_DB_NAME=metrics
SYSLOG_DB_USER=postgres
SYSLOG_DB_PASSWORD=CHANGE_ME
SYSLOG_DB_SSLMODE=prefer

# Optional: filter queries to a single FortiGate host IP (matches syslog_events.host)
FGT_HOST=10.20.11.29
